{
  "name": "better-git-vscode",
  "displayName": "Better Git VS Code",
  "description": "Fast keyboard-driven git diff review \u2014 jump between changes and changed files, stage-and-advance, revert, all without the mouse.",
  "version": "1.0.2",
  "icon": "src/icon.png",
  "engines": {
    "vscode": "^1.83.0"
  },
  "keywords": [
    "next",
    "change",
    "changed",
    "file",
    "files",
    "shortcut",
    "hotkey",
    "git",
    "scm",
    "source control",
    "cycle",
    "previous"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EthanSK/better-git-vscode"
  },
  "publisher": "EthanSK",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "better-git-vscode.next-scm-change",
        "title": "Next git change"
      },
      {
        "command": "better-git-vscode.previous-scm-change",
        "title": "Previous git change"
      },
      {
        "command": "better-git-vscode.next-changed-file",
        "title": "Next changed file"
      },
      {
        "command": "better-git-vscode.previous-changed-file",
        "title": "Previous changed file"
      },
      {
        "command": "better-git-vscode.revert-and-save",
        "title": "Revert selected changes and save"
      },
      {
        "command": "better-git-vscode.stage-and-next-changed-file",
        "title": "Stage current file and advance to next unstaged change"
      },
      {
        "command": "better-git-vscode.stage-and-previous-changed-file",
        "title": "Stage current file and advance to previous unstaged change"
      },
      {
        "command": "better-git-vscode.stage-current-file",
        "title": "Stage current file",
        "icon": "$(add)"
      },
      {
        "command": "better-git-vscode.smart-forward",
        "title": "Smart forward (next change in a diff, else navigate forward)"
      },
      {
        "command": "better-git-vscode.smart-back",
        "title": "Smart back (previous change in a diff, else navigate back)"
      },
      {
        "command": "better-git-vscode.reveal-current-file-in-explorer",
        "title": "Open & reveal current file in Explorer (works from staged diffs)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "better-git-vscode.stage-current-file",
          "group": "navigation",
          "when": "gitOpenRepositoryCount != 0"
        }
      ]
    },
    "configuration": {
      "title": "Better Git VS Code",
      "properties": {
        "better-git-vscode.treeView": {
          "type": "boolean",
          "default": false,
          "description": "Check this If you use Tree view (as opposed to List view)"
        },
        "better-git-vscode.shouldOpenScmView": {
          "type": "boolean",
          "default": true,
          "description": "Controls whether the source control side panel should open when going to next/previous change"
        },
        "better-git-vscode.revealStagedInSourceControl": {
          "type": "boolean",
          "default": false,
          "description": "Experimental: also select/highlight staged files in the Source Control view while navigating (works around a VS Code limitation where staged diffs can't be auto-revealed). May cause a brief flash of the file, and for partially-staged files highlights the unstaged copy. Requires scm.autoReveal (on by default)."
        },
        "better-git-vscode.currentFileBadge": {
          "type": "string",
          "default": "\ud83d\udd25\ud83d\udd25",
          "description": "The badge shown on the file you're currently reviewing, in the Source Control panel (and Explorer/tabs). Max 2 characters \u2014 an emoji renders in colour and is the most visible option (the Source Control panel ignores decoration colours). Default is double fire \ud83d\udd25\ud83d\udd25. Loud choices: \ud83d\udd25 \ud83d\udd34 \ud83d\udea8 \ud83d\udfe5 \u2757 \u2b50 \ud83d\udc49. Tip: two emoji (e.g. \ud83d\udd25\ud83d\udd25) is allowed and renders a bit wider. Set to empty to disable the badge."
        }
      }
    },
    "keybindings": [
      {
        "command": "better-git-vscode.smart-forward",
        "key": "alt+.",
        "mac": "alt+."
      },
      {
        "command": "better-git-vscode.smart-back",
        "key": "alt+,",
        "mac": "alt+,"
      },
      {
        "command": "better-git-vscode.next-scm-change",
        "key": "alt+z",
        "mac": "alt+z"
      },
      {
        "command": "better-git-vscode.previous-scm-change",
        "key": "alt+a",
        "mac": "alt+a"
      },
      {
        "command": "better-git-vscode.next-changed-file",
        "key": "ctrl+alt+.",
        "mac": "cmd+alt+."
      },
      {
        "command": "better-git-vscode.previous-changed-file",
        "key": "ctrl+alt+,",
        "mac": "cmd+alt+,"
      },
      {
        "command": "better-git-vscode.stage-and-next-changed-file",
        "key": "shift+alt+.",
        "mac": "shift+alt+."
      },
      {
        "command": "better-git-vscode.stage-and-previous-changed-file",
        "key": "shift+alt+,",
        "mac": "shift+alt+,"
      },
      {
        "command": "better-git-vscode.revert-and-save",
        "key": "alt+q",
        "mac": "alt+q"
      },
      {
        "command": "better-git-vscode.reveal-current-file-in-explorer",
        "key": "alt+r",
        "mac": "alt+r"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.83.0",
    "@types/mocha": "^10.0.3",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2",
    "ts-loader": "^9.5.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "@vscode/test-electron": "^2.3.6"
  }
}
